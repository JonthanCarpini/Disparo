        "jsCode": "const groups = $input.first().json.data;\nif (!groups || !Array.isArray(groups)) {\n  throw new Error('Resposta inesperada da API: campo data ausente');\n}\nreturn groups.map(group => ({\n  json: {\n    groupJid: group.id,\n    subject: group.subject\n  }\n}));"
